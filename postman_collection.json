            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Test Student\",\n  \"description\": \"Updated description for testing\",\n  \"age\": 21,\n  \"career\": \"Software Engineering\",\n  \"hobbies\": \"Programming, Reading, Gaming\"\n}"
            },
