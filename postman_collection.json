                "description": "Reemplaza con tu API key del login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Obtiene información detallada del usuario actual incluyendo información del API key."
          },
          "response": []
        },
