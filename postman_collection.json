            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"invalid_user\",\n  \"email\": \"invalid@example.com\",\n  \"password\": \"TestPass123\",\n  \"name\": \"Invalid User\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
