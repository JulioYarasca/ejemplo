            "url": {
              "raw": "{{base_url}}/api/auth/session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "session"
              ]
            },
            "description": "Obtiene información de la sesión actual usando API key."
          },
          "response": []
        },
