        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "REPLACE_WITH_YOUR_API_KEY",
                "description": "Reemplaza con tu API key del login"
              }
